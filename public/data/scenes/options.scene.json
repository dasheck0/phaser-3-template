			},
			"properties": {
				"text": "options.language",
				"style": { "fontSize": "20px", "color": "#cccccc" },
				"space": { "left": 0, "right": 0, "top": 0, "bottom": 0 }
			}
		},
		{
			"type": "LanguageChooser",
			"id": "languageChooser",
			"layout": {
				"space": "safe",
				"anchor": { "centerX": "center", "centerY": "center" }
			},
			"properties": {
				"activeLocale": "en",
				"options": [
					{ "locale": "de", "key": "deFlag" },
					{ "locale": "en", "key": "enFlag" },
					{ "locale": "es", "key": "esFlag" },
					{ "locale": "fr", "key": "frFlag" },
					{ "locale": "it", "key": "itFlag" },
					{ "locale": "nl", "key": "nlFlag" },
					{ "locale": "pl", "key": "plFlag" },
					{ "locale": "pt", "key": "ptFlag" }
				],
				"columns": 4,
				"gridWidth": 240,
				"cellPadding": 8,
				"iconPadding": 6,
				"indicatorShape": "circle",
				"activeBorderColor": 6737151,
				"activeBorderWidth": 3,
				"inactiveBorderColor": 6052956,
				"inactiveBorderWidth": 0,
				"backgroundColor": 1841439,
				"backgroundAlpha": 0,
				"depth": 100
			}
		},
