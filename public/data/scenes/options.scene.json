	"prefabs": [
		{
			"type": "Label",
			"id": "titleLabel",
			"layout": {
				"space": "safe",
				"anchor": { "centerX": "center", "top": "top+130" }
			},
			"properties": {
				"text": "options.title",
				"style": {
					"fontSize": "36px",
					"color": "#ffffff",
					"fontStyle": "bold"
				},
				"space": { "left": 10, "right": 10, "top": 8, "bottom": 8 },
