				"space": { "left": 0, "right": 0, "top": 0, "bottom": 0 }
			}
		},
		{
			"type": "Slider",
			"id": "masterVolumeSlider",
			"layout": {
				"space": "safe",
				"anchor": { "centerX": "center+60", "top": "top+255" }
			},
			"properties": {
				"width": 260,
				"height": 20,
				"orientation": "x",
				"value": 1,
				"track": { "width": 260, "height": 6, "radius": 3, "color": 4473924 },
				"thumb": { "width": 24, "height": 24, "radius": 12, "color": 4890082 },
				"input": "drag"
			}
		},
		{
			"type": "Label",
			"id": "languageLabel",
			"layout": {
