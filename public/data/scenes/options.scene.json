				"anchor": { "centerX": "center", "top": "top+475" }
			},
			"properties": {
				"text": "options.backButton",
				"style": { "fontSize": "20px", "color": "#ffffff" },
				"background": {
					"radius": 6,
					"color": 4890082,
					"strokeColor": 3505853,
					"strokeWidth": 2
				},
				"space": { "left": 32, "right": 32, "top": 12, "bottom": 12 },
				"align": "center",
				"setInteractive": true
			}
		},
		{
			"type": "Label",
			"id": "keyboardHint",
			"layout": {
				"space": "safe",
				"anchor": { "centerX": "center", "top": "top+585" }
